body {
	width: 100%;
	height: 100%;
	margin: 0px;
	font-family: Maplestory;
	font-weight: bold;
	text-align: center;
}

#pause-menu-overlay {
	position: absolute;
	left: 0px;
	top: 0px;
	width: 100%;
	height: 100%;
	background-color: #00000088;
}

#pause-menu-panel {
	position: absolute;
	left: 50%;
	top: 50%;
	width: 380dp;
	height: 280dp;
	margin-left: -190dp;
	margin-top: -140dp;
	border-width: 3dp;
	border-color: #f0c85a;
	background-color: #15171c;
}

#pause-menu-title {
	position: absolute;
	left: 0px;
	top: 24dp;
	width: 100%;
	height: 40dp;
	color: #f0c85a;
	font-family: Maplestory;
	font-weight: bold;
	font-size: 28dp;
	line-height: 40dp;
	text-align: center;
}

#pause-menu-go-intro-button {
	position: absolute;
	left: 50%;
	top: 100dp;
	width: 280dp;
	height: 56dp;
	margin-left: -140dp;
	border-width: 3dp;
	border-color: #f0c85a;
	background-color: #252a34;
	color: #ffffff;
	font-family: Maplestory;
	font-weight: bold;
	font-size: 22dp;
	line-height: 50dp;
	text-align: center;
}

#pause-menu-exit-button {
	position: absolute;
	left: 50%;
	top: 180dp;
	width: 280dp;
	height: 56dp;
	margin-left: -140dp;
	border-width: 3dp;
	border-color: #f0c85a;
	background-color: #252a34;
	color: #ffffff;
	font-family: Maplestory;
	font-weight: bold;
	font-size: 22dp;
	line-height: 50dp;
	text-align: center;
}
